# ============================================================
# Mobile Device Collector — Environment Configuration
#
# LOCAL DEVELOPMENT:
#   Copy this file to .env and fill in real values.
#   Never commit .env to version control.
#
# SAGEMAKER / PRODUCTION:
#   Do NOT use a .env file on SageMaker.
#   Export environment variables directly in your terminal:
#     export OPENAI_API_KEY="sk-proj-..."
#   Or store the key in AWS Secrets Manager and inject it at runtime.
#   pydantic-settings reads OS env vars first — .env is not required.
# ============================================================

# ---- Required -----------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---- OpenAI Model Settings ----------------------------------
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=6000
OPENAI_TIMEOUT=120.0
OPENAI_MAX_RETRIES=3

# ---- Batching & Concurrency ---------------------------------
# Recommended for 25k records on gpt-4o-mini:
#   BATCH_SIZE=20, MAX_CONCURRENCY=8  → ~78 min, ~$2.90
#   BATCH_SIZE=20, MAX_CONCURRENCY=10 → ~62 min (Tier 2+ only)
BATCH_SIZE=20
MAX_CONCURRENCY=8
TOKEN_BUDGET_PER_BATCH=12000

# ---- Logging ------------------------------------------------
LOG_LEVEL=INFO

# ---- Caching ------------------------------------------------
ENABLE_CACHE=true

# ---- Cost Tracking (gpt-4o-mini defaults) -------------------
COST_PER_1K_INPUT_TOKENS=0.00015
COST_PER_1K_OUTPUT_TOKENS=0.0006
